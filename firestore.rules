rules_version = '2';
// Firestore Security Rules — triple-map system (agents, groups & families), trips open to all signed-in users
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isContentManager() {
      return isSignedIn() && userRole() == 'content_manager';
    }

    function isAdminOrContentManager() {
      return isAdmin() || isContentManager();
    }

    function isBusinessUser() {
      return isSignedIn() && userRole() == 'business_user';
    }

    function isTravelAgent() {
      return isSignedIn() && userRole() == 'travel_agent';
    }

    function isCrmUser() {
      return isSignedIn() && userRole() == 'crm_user';
    }

    function isCrmAuthorized() {
      return isAdmin() || isCrmUser();
    }

    // ─── points_of_interest ─────────────────────────────────────────────────

    match /points_of_interest/{poiId} {
      allow read: if isAdminOrContentManager() ||
                     (isBusinessUser() && resource.data.businessId == request.auth.uid) ||
                     // Default POIs (agents/groups shared) — requires sign-in
                     (resource.data.mapType == 'default' &&
                       ((isTravelAgent() && resource.data.active == true && resource.data.maps.agents.active == true) ||
                        (isSignedIn() && resource.data.active == true && resource.data.maps.groups.active == true))) ||
                     // Families POIs — visible to signed-in users when active
                     (isSignedIn() && resource.data.mapType == 'families' && resource.data.active == true);

      allow create: if isAdminOrContentManager() &&
                       request.resource.data.mapType in ['default', 'families'];
      allow delete: if isAdmin();

      allow update: if isAdminOrContentManager() ||
        (isBusinessUser() &&
         resource.data.businessId != null &&
         get(/databases/$(database)/documents/businesses/$(resource.data.businessId))
           .data.associatedUserIds.hasAny([request.auth.uid]) &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['mainImage', 'description', 'images', 'videos', 'phone', 'whatsapp', 'email', 'website', 'kashrutCertUrl', 'menuUrl', 'facebook', 'openingHours', 'price', 'minPeople', 'maxPeople', 'updatedAt'])
        );
    }

    // ─── clicks ─────────────────────────────────────────────────────────────

    match /clicks/{clickId} {
      allow create: if
        !(isSignedIn() && (userRole() == 'admin' || userRole() == 'content_manager')) &&
        !(isSignedIn() && userRole() == 'business_user' &&
          get(/databases/$(database)/documents/points_of_interest/$(request.resource.data.poiId)).data.businessId == request.auth.uid) &&
        request.resource.data.keys().hasAll(['poiId', 'categoryId', 'timestamp']) &&
        request.resource.data.keys().hasOnly(['poiId', 'categoryId', 'timestamp']) &&
        request.resource.data.poiId is string &&
        request.resource.data.categoryId is string &&
        request.resource.data.poiId.size() < 100 &&
        request.resource.data.categoryId.size() < 100;

      allow read, delete: if isAdmin();
    }

    // ─── categories ─────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrContentManager();
    }

    // ─── subcategories ──────────────────────────────────────────────────────

    match /subcategories/{subcategoryId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrContentManager();
    }

    // ─── icons ──────────────────────────────────────────────────────────────

    match /icons/{iconId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrContentManager();
    }

    // ─── businesses ─────────────────────────────────────────────────────────

    match /businesses/{businessId} {
      allow write: if isAdmin();

      allow read: if isAdmin() ||
        (isBusinessUser() && request.auth.uid == businessId);
    }

    // ─── settings ───────────────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── trips ──────────────────────────────────────────────────────────────

    match /trips/{tripId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow get: if resource.data.isShared == true;
    }

    // ─── CRM contacts ──────────────────────────────────────────────────

    match /crm_contacts/{contactId} {
      allow read: if isCrmAuthorized();
      allow create: if isCrmAuthorized() &&
        request.resource.data.keys().hasOnly([
          'name', 'businessName', 'phone', 'email',
          'createdBy', 'createdByEmail', 'createdAt', 'updatedAt'
        ]) &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isCrmAuthorized() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'businessName', 'phone', 'email', 'updatedAt'
        ]);
      allow delete: if isAdmin();

      match /activity_log/{logId} {
        allow read: if isCrmAuthorized();
        allow create: if isCrmAuthorized() &&
          request.resource.data.keys().hasOnly([
            'text', 'createdBy', 'createdByEmail', 'createdAt'
          ]) &&
          request.resource.data.createdBy == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // ─── CRM tasks ────────────────────────────────────────────────────

    match /crm_tasks/{taskId} {
      allow read: if isCrmAuthorized();
      allow create: if isCrmAuthorized() &&
        request.resource.data.keys().hasOnly([
          'contactId', 'contactName', 'title', 'description',
          'date', 'color', 'priority', 'assigneeUid', 'assigneeEmail',
          'followers', 'createdBy', 'createdByEmail', 'completed',
          'createdAt', 'updatedAt'
        ]) &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isCrmAuthorized() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'description', 'date', 'color', 'priority',
          'assigneeUid', 'assigneeEmail', 'contactId', 'contactName',
          'followers', 'completed', 'updatedAt'
        ]);
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isCrmAuthorized();
        allow create: if isCrmAuthorized() &&
          request.resource.data.keys().hasOnly([
            'text', 'createdBy', 'createdByEmail', 'createdAt'
          ]) &&
          request.resource.data.createdBy == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // ─── users ──────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow read: if isCrmUser();
      allow update: if isSignedIn() &&
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'businessRef']);
    }
  }
}
